---
import { siteConfig } from '../data/config';
import { heroCode } from '../data/hero-code';
import Icon from './Icon.astro';

async function getGitHubStars(): Promise<number | null> {
  try {
    const response = await fetch('https://api.github.com/repos/LarsArtmann/clean-wizard', {
      headers: {
        'Accept': 'application/vnd.github.v3+json',
      },
    });
    if (!response.ok) return null;
    const data = await response.json();
    return data.stargazers_count as number;
  } catch {
    return null;
  }
}

const stars = await getGitHubStars();
const showStars = stars !== null && stars >= 10;
const starsText = showStars ? `${stars} Stars` : 'View on GitHub';

const highlightedCode = `<span class="text-text-muted">$</span> clean-wizard scan

<span class="text-text-secondary">Scanning system for cleanable items...</span>

<span class="text-success">Found</span> 11 available cleaner(s)

  <span class="text-text-primary">System Cache</span>          9 items    <span class="text-amber">20 GiB</span>
  <span class="text-text-primary">Compiled Binaries</span>     162 items   <span class="text-amber">5.1 GiB</span>
  <span class="text-text-primary">Go Packages</span>           2 items    <span class="text-amber">11 GiB</span>
  <span class="text-text-primary">Cargo Packages</span>        2 items     <span class="text-amber">1.6 GiB</span>
  <span class="text-text-primary">golangci-lint Cache</span>   1 item      <span class="text-amber">2.2 MiB</span>
  <span class="text-text-primary">Project Executables</span>   1 item      <span class="text-amber">100 MiB</span>

<span class="text-accent">Total cleanable: 38 GiB (177 items)</span>

<span class="text-text-muted">$</span> clean-wizard clean <span class="text-accent">--mode</span> quick <span class="text-accent">--dry-run</span>

<span class="text-text-secondary">Found 11 available cleaner(s)</span>
<span class="text-text-secondary">Using preset mode: quick</span>
  Homebrew
  Node.js Packages
  Go Packages
  Temp Files
  Build Cache

<span class="text-text-secondary">Starting cleanup... (DRY RUN)</span>

  <span class="text-text-primary">buildcache</span>    3 items    <span class="text-amber">900 MiB</span>
  <span class="text-text-primary">go</span>            2 items    <span class="text-amber">11 GiB</span>

<span class="text-accent">Total: 12 GiB freed, 6 items in 1.1s</span>

<span class="text-text-muted">$</span> clean-wizard clean <span class="text-accent">--mode</span> quick

<span class="text-text-secondary">Cleanup Results</span>

  <span class="text-text-primary">buildcache</span>    3 items    <span class="text-success">900 MiB</span>
  <span class="text-text-primary">go</span>            2 items    <span class="text-success">11 GiB</span>

<span class="text-accent">Total: 12 GiB freed in 1.1s</span>`;

const metrics = [
  { value: '13', label: 'Caches covered' },
  { value: '2', label: 'Platforms' },
  { value: '1', label: 'Command for all' },
  { value: '0', label: 'Files lost' },
];
---

<section class="relative flex items-center justify-center overflow-hidden pt-36 pb-20">
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-accent/5 blur-[140px] rounded-full pointer-events-none"></div>
  <div class="relative max-w-3xl xl:max-w-7xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-border bg-bg-card-solid text-xs font-mono text-text-secondary mb-8 backdrop-blur-sm">
      <span class="relative flex w-2 h-2">
        <span class="animate-pulse-dot absolute inline-flex w-full h-full rounded-full bg-accent"></span>
        <span class="relative inline-flex rounded-full w-2 h-2 bg-accent"></span>
      </span>
      Open source disk cleaner for developers
    </div>

    <h1 class="text-[clamp(2.75rem,8vw,4.5rem)] font-bold tracking-tighter leading-[1.05] mb-6 text-text-primary">
      One command to clean <span class="text-accent">every dev cache</span> on your machine.
    </h1>

    <p class="text-[clamp(1.0625rem,2.5vw,1.25rem)] text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
      Go build caches, Docker images, Nix generations, Homebrew downloads, node_modules, Cargo registries, and 7 more. Preview before deleting, automate with JSON, never lose what matters.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-12">
      <a href="/getting-started/quick-start/" data-astro-prefetch class="px-6 py-3 bg-accent text-bg-primary font-semibold rounded-lg text-sm hover:bg-accent-hover transition-all duration-200 inline-flex items-center gap-2 border-none cursor-pointer shadow-lg shadow-accent/20 hover:shadow-accent/30 hover:-translate-y-0.5">
        Quick Start Guide
        <Icon name="arrow-right" size={16} />
      </a>
      <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="px-6 py-3 border border-border text-text-secondary font-medium rounded-lg text-sm hover:border-border-hover hover:text-text-primary transition-all duration-200 inline-flex items-center gap-2 no-underline hover:-translate-y-0.5">
        <Icon name="star" size={14} />
        {starsText}
      </a>
    </div>

    <div class="flex items-center justify-center gap-6 md:gap-10 mb-16 max-w-xl mx-auto">
      {metrics.map((metric, index) => (
        <>
          {index > 0 && <div class="w-px h-10 bg-border shrink-0"></div>}
          <div class="text-center">
            <div class="text-xl font-bold text-text-primary font-mono">{metric.value}</div>
            <div class="text-xs text-text-muted mt-0.5">{metric.label}</div>
          </div>
        </>
      ))}
    </div>

    <div class="relative max-w-xl mx-auto">
      <div class="absolute -inset-4 bg-gradient-to-r from-accent/8 via-transparent to-accent/8 rounded-2xl pointer-events-none"></div>
      <div class="relative rounded-xl border border-border bg-bg-code shadow-2xl overflow-hidden code-preview">
        <div class="flex items-center gap-1.5 px-4 py-3 border-b border-border bg-bg-card-solid/50">
          {Array(3).fill(null).map(() => (
            <span class="w-2.5 h-2.5 rounded-full bg-code-dot"></span>
          ))}
          <span class="ml-3 text-xs text-text-muted font-mono">terminal</span>
        </div>
        <pre class="p-5 text-left text-[0.8125rem] font-mono leading-[1.7] overflow-x-auto relative"><code id="hero-code" set:html={highlightedCode} /></pre>
        <button class="absolute top-2 right-2 bg-code-inline-bg/80 border border-border rounded-md text-text-muted px-2 py-1 cursor-pointer text-xs font-mono hover:text-text-primary hover:border-border-hover transition-all duration-150 opacity-0 [.code-preview:hover_&]:opacity-100" id="copy-btn" data-code={heroCode} aria-label="Copy code to clipboard">Copy</button>
      </div>
    </div>
  </div>
</section>

<script is:inline src="/js/copy-code.js"></script>
